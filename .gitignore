# ============================================
# PROJECT-SPECIFIC EXCLUSIONS
# ============================================

# Model checkpoints (keep trained models, exclude checkpoints)
models/checkpoints/
models/plots/

# Data files — too large for GitHub (1.5GB raw + 910MB processed)
data/raw/
data/processed/*.csv
data/sequences/
datasets/

# Keep .gitkeep and metadata files
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/metadata.json

